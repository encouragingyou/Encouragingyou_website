# Canonical public URL for the environment being built.
# Keep all real tokens, inbox addresses, and provider secrets server-side only.
SITE_URL=https://www.example.com

# Optional local override. Leave unset on Render so the app can detect production
# from RENDER=true and previews from IS_PULL_REQUEST=true.
# DEPLOYMENT_CHANNEL=local
# DEPLOYMENT_SURFACE=shared

# Optional release metadata for local verification or ad-hoc packaged builds.
# RELEASE_ID=
# RELEASE_SHA=
# RELEASE_CREATED_AT=

# Playwright defaults. Leave unset unless you need to target an existing server.
# PLAYWRIGHT_BASE_URL=
# PLAYWRIGHT_PORT=4173

# Server-side enquiry queue. Leave unset to use ./var/enquiries.
# ENQUIRY_STORAGE_DIR=

# Server-side aggregate analytics store. Leave unset to use ./var/analytics.
# ANALYTICS_STORAGE_DIR=
# ANALYTICS_MODE=statistical

# Isolated admin portal runtime. Keep these server-side only, and prefer using
# them on a dedicated admin deployment or origin rather than the public site.
# ADMIN_PORTAL_ENABLED=true
# ADMIN_ORIGIN_URL=https://admin.example.com
# ADMIN_ADDITIONAL_ALLOWED_ORIGINS=
# ADMIN_STORAGE_DIR=
# ADMIN_TOTP_ENCRYPTION_KEYS=key-2026-04:BASE64_32_BYTE_KEY

# Local and CI only. Never enable bootstrap accounts on a public deployment.
# ADMIN_ENABLE_DEV_BOOTSTRAP=false

# Auth policy defaults.
# ADMIN_SESSION_IDLE_MINUTES=30
# ADMIN_SESSION_ABSOLUTE_HOURS=8
# ADMIN_PENDING_MFA_MINUTES=10
# ADMIN_INVITATION_EXPIRY_HOURS=168
# ADMIN_LOGIN_LOCKOUT_MINUTES=15
# ADMIN_MAX_CONCURRENT_SESSIONS=5
# ADMIN_MAX_FAILED_PASSWORDS=5
# ADMIN_PASSWORD_MIN_LENGTH=12
# ADMIN_RECENT_AUTH_MINUTES=10

# Legacy prototype preview only. These are only used by npm run preview:prototype.
# HOST=127.0.0.1
# PORT=4173

# Reserved for later prompts. Do not set until the related feature exists.
# Never introduce PUBLIC_ secrets for this site.
# CMS_READ_TOKEN=
