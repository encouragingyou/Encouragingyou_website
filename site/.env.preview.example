# Optional local preview simulation file.
# On Render PR previews, leave DEPLOYMENT_CHANNEL unset and let IS_PULL_REQUEST=true
# switch the app into preview-safe mode automatically.
SITE_URL=
DEPLOYMENT_CHANNEL=preview
DEPLOYMENT_SURFACE=public
ANALYTICS_MODE=off

# Optional release metadata for a named preview build.
# RELEASE_ID=
# RELEASE_SHA=
# RELEASE_CREATED_AT=

# Preview and CI deployments automatically write form/analytics data to a temp
# directory so they never reuse production storage paths. Leave these unset unless
# you are simulating a custom preview locally.
# ENQUIRY_STORAGE_DIR=
# ANALYTICS_STORAGE_DIR=

# Public preview safety: keep the admin portal on its own deployment/origin.
# If you deliberately simulate the admin runtime locally, set the values below in
# a separate local override instead of sharing them with the public preview.
# ADMIN_PORTAL_ENABLED=false
# ADMIN_ORIGIN_URL=
# ADMIN_ADDITIONAL_ALLOWED_ORIGINS=
# ADMIN_STORAGE_DIR=
# ADMIN_TOTP_ENCRYPTION_KEYS=
# ADMIN_ENABLE_DEV_BOOTSTRAP=false

# Reserved for later prompts.
# CMS_READ_TOKEN=
