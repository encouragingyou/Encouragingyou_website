---
import PageSection from "../components/layout/PageSection.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import SiteLayout from "../layouts/BaseLayout.astro";
import ActionCard from "../components/ui/ActionCard.astro";
import ActionCluster from "../components/ui/ActionCluster.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getHomePageModel } from "../lib/content/site-content";
import { getMediaAsset } from "../lib/media/catalog";
import type { ActionLink } from "../lib/types/site-ui";

const home = getHomePageModel();

const routeHubCards = [
  {
    title: "Join a session",
    summary: "See Saturday session times, what happens, and how to ask before you come.",
    href: "/sessions/",
    icon: getMediaAsset("icon-youth-activities")
  },
  {
    title: "Get CV help",
    summary:
      "Get real help writing your CV, applying for jobs, and preparing for interviews.",
    href: "/programmes/career-support-cv-help/",
    icon: getMediaAsset("icon-cv-support")
  },
  {
    title: "Visit youth club",
    summary:
      "Games, conversation, and low-pressure friendship in a place people can feel comfortable returning to.",
    href: "/sessions/youth-club/",
    icon: getMediaAsset("icon-community-event")
  },
  {
    title: "Programmes",
    summary:
      "Explore confidence, life skills, motivation, friendship, and practical next steps.",
    href: "/programmes/",
    icon: getMediaAsset("icon-growth")
  },
  {
    title: "About",
    summary: "See why EncouragingYou exists and how youth-led support shapes the work.",
    href: "/about/",
    icon: getMediaAsset("icon-mentoring")
  },
  {
    title: "Get involved",
    summary: "Volunteer, partner, refer someone, or offer practical local support.",
    href: "/get-involved/",
    icon: getMediaAsset("icon-intergenerational-connection")
  },
  {
    title: "Ask a question",
    summary:
      "Send a short message if you are unsure what fits or want to check timing, privacy, or safety.",
    href: "/contact/",
    icon: getMediaAsset("icon-contact")
  },
  {
    title: "Safeguarding",
    summary: "Find the safety route and what to do if you are worried about someone.",
    href: "/safeguarding/",
    icon: getMediaAsset("icon-safe-space")
  }
];

const introItems = [
  {
    title: "Who it is for",
    summary:
      "Young people in Rochdale who want support, friendship, confidence, or a clearer next step."
  },
  {
    title: "What happens",
    summary:
      "Youth club, CV and application help, confidence-building, low-pressure friendship, and practical support."
  },
  {
    title: "Why it matters",
    summary:
      "We help young people speak up, make friends, and feel more confident in real-life situations."
  }
];

const reassuranceActions: ActionLink[] = [
  {
    label: "Ask a question",
    href: "/contact/",
    variant: "primary"
  },
  {
    label: "Safeguarding information",
    href: "/safeguarding/",
    variant: "surface"
  },
  {
    label: "Privacy notice",
    href: "/privacy/",
    variant: "text"
  }
];
---

<SiteLayout
  meta={home.meta}
  currentPath="/"
  pageId="home"
  structuredData={home.structuredData}
>
  <HomeHero {...home.hero} />

  <PageSection id="route-hub" tone="tint" width="wide">
    <section class="home-route-hub" data-home-section="route-hub">
      <div class="home-route-hub__intro">
        <SectionHeading
          eyebrow="Start here"
          title="Choose the route that fits today."
          summary="Support starts with a simple choice: join a session, get CV help, visit youth club, explore programmes, or ask a question."
          width="standalone"
        />

        <div class="home-intro-grid">
          {
            introItems.map((item) => (
              <article class="home-intro-item">
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </article>
            ))
          }
        </div>
      </div>

      <div class="home-route-grid layout-grid layout-grid--cards">
        {routeHubCards.map((card) => <ActionCard {...card} />)}
      </div>
    </section>
  </PageSection>

  <PageSection id="home-reassurance" width="wide">
    <section class="home-reassurance" data-home-section="home-reassurance">
      <div class="home-reassurance__copy">
        <p class="eyebrow">Still unsure?</p>
        <h2>Ask a question before you choose.</h2>
        <p class="home-reassurance__summary">
          If you want to check timing, fit, privacy, or safety, send a short message and
          the team can point you to the right route.
        </p>
      </div>
      <ActionCluster actions={reassuranceActions} className="home-reassurance__actions" />
    </section>
  </PageSection>
</SiteLayout>
