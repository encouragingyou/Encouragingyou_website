---
import ActionCluster from "./ActionCluster.astro";
import type { ActionLink } from "../../lib/types/site-ui";

interface Props {
  actions?: ActionLink[];
  body?: string;
  bullets?: string[];
  className?: string;
  eyebrow?: string;
  headingLevel?: 1 | 2 | 3;
  presentation?: "panel" | "status";
  stateId?: string;
  summary?: string;
  title: string;
  tone?: "default" | "error" | "info" | "important" | "success";
}

const {
  actions = [],
  body,
  bullets = [],
  className = "",
  eyebrow,
  headingLevel = 2,
  presentation = "panel",
  stateId = "empty-valid",
  summary,
  title,
  tone = "default"
} = Astro.props;

const HeadingTag = `h${headingLevel}` as "h1" | "h2" | "h3";
const panelClassName = [
  "resilience-panel",
  `resilience-panel--${presentation}`,
  tone !== "default" ? `resilience-panel--${tone}` : "",
  className
]
  .filter(Boolean)
  .join(" ");
---

<section
  class={panelClassName}
  data-resilience-state={stateId}
  data-resilience-presentation={presentation}
  data-tone={tone}
>
  {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
  <HeadingTag>{title}</HeadingTag>
  {summary ? <p class="resilience-panel__summary">{summary}</p> : null}
  {body ? <p class="resilience-panel__body-copy">{body}</p> : null}

  {
    bullets.length > 0 ? (
      <ul class="check-list resilience-panel__list">
        {bullets.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    ) : null
  }

  {actions.length > 0 ? <ActionCluster actions={actions} /> : null}
</section>
