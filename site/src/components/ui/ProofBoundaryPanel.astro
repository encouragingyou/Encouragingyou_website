---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
  publishNow: string[];
  awaitingConfirmation: string[];
  withheldUntilVerified: string[];
}

const {
  eyebrow,
  title,
  summary,
  publishNow,
  awaitingConfirmation,
  withheldUntilVerified
} = Astro.props;
---

<aside class="proof-boundary" aria-labelledby="proof-boundary-title">
  {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
  <h2 id="proof-boundary-title">{title}</h2>
  {summary ? <p class="proof-boundary__summary">{summary}</p> : null}

  <div class="proof-boundary__groups">
    <section class="proof-boundary__group">
      <h3>Safe to publish now</h3>
      <ul>
        {publishNow.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="proof-boundary__group">
      <h3>Still waiting for approval</h3>
      <ul>
        {awaitingConfirmation.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="proof-boundary__group">
      <h3>Held back until verified</h3>
      <ul>
        {withheldUntilVerified.map((item) => <li>{item}</li>)}
      </ul>
    </section>
  </div>
</aside>
