---
import CardPanel from "./CardPanel.astro";
import type { MediaAsset } from "../../lib/types/site-ui";

interface Props {
  title: string;
  summary: string;
  href: string;
  icon: MediaAsset;
}

const { title, summary, href, icon } = Astro.props;
---

<CardPanel
  className="action-card"
  heading={title}
  headingLevel={3}
  href={href}
  icon={icon}
  summary={summary}
/>
